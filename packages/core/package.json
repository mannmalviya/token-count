{
  "name": "@token-count/core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared library: transcript parsing, storage, aggregation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
