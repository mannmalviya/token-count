{
  "name": "token-count-vscode",
  "displayName": "Token Count",
  "description": "Live Claude Code token usage in the status bar + a dashboard.",
  "version": "0.1.0",
  "publisher": "MannMalviya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mannmalviya/token-count.git"
  },
  "bugs": {
    "url": "https://github.com/mannmalviya/token-count/issues"
  },
  "homepage": "https://github.com/mannmalviya/token-count#readme",
  "icon": "resources/icon.png",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "tokens",
    "usage",
    "dashboard",
    "cost"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tokenCount.showDashboard",
        "title": "Token Count: Show Dashboard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokenCount",
          "title": "Token Count",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tokenCount": [
        {
          "type": "webview",
          "id": "tokenCount.sidebar",
          "name": "Usage Summary"
        }
      ]
    },
    "configuration": {
      "title": "Token Count",
      "properties": {
        "tokenCount.rightStatusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a second status bar item on the right with a rich hover tooltip quick-peek."
        },
        "tokenCount.useLocalTimezone": {
          "type": "boolean",
          "default": true,
          "description": "Bucket per-day stats at your machine's local-midnight boundary (default). Turn off to bucket at UTC midnight instead — useful if you want numbers to match the CLI's --utc output exactly. Affects the dashboard charts, the sidebar, and the status bar tooltips."
        }
      }
    }
  },
  "categories": ["Visualization", "Other"],
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@token-count/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0"
  }
}
